# Copy to .env and fill in values (see README)

# AI — set at least one (Groq is free: https://console.groq.com)
GROQ_API_KEY=
# Optional: default Groq model when client config uses an OpenAI model id
# GROQ_MODEL=llama-3.3-70b-versatile

OPENAI_API_KEY=

PORT=3000
NODE_ENV=development
# Comma-separated. Add every origin that loads the UI (e.g. Railway + local).
# On Railway, https://YOUR_DOMAIN is also added automatically from RAILWAY_PUBLIC_DOMAIN.
ALLOWED_ORIGINS=http://localhost:3000
# CORS_EXTRA_ORIGINS=https://another-preview.example.com

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_PHONE_FROM=

SERPAPI_KEY=
